# Lab 28 — environment variables
# Copy to .env then fill in real values.

# ── Kaggle GPU tunnels (lấy từ Kaggle notebook sau khi ngrok.connect()) ──
VLLM_NGROK_URL=https://xxxxxxxx.ngrok-free.app
EMBED_NGROK_URL=https://yyyyyyyy.ngrok-free.app

# ── Mapping vào API Gateway container ──
# docker-compose injects VLLM_URL=${VLLM_NGROK_URL} automatically.
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-GPTQ-Int4

# ── LangSmith / LangChain LLMOps ──
LANGCHAIN_API_KEY=ls__your_langsmith_key_here
LANGCHAIN_PROJECT=lab28-platform
LANGCHAIN_TRACING_V2=true

# ── Local service hosts (chỉ override khi chạy script bên ngoài Docker network) ──
KAFKA_BOOTSTRAP=localhost:29092
QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_HOST=localhost

# ── Smoke test tuning ──
LATENCY_BUDGET_MS=10000
